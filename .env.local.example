# ─────────────────────────────────────────────────────────────
# Notion 기반 견적서 웹 서비스 — 환경변수 템플릿
# 이 파일을 `.env.local`로 복사 후 실제 값을 채워 사용하세요.
# ─────────────────────────────────────────────────────────────

# 발급: Slack → 앱 관리 → Incoming Webhooks → Webhook URL 복사
SLACK_WEBHOOK_URL=

# Notion Integration
# 발급: https://www.notion.so/my-integrations
NOTION_API_KEY=your-notion-api-key-here

# 노션 데이터베이스 ID (URL의 32자리 hex 문자열)
# 견적서 DB
NOTION_INVOICE_DB_ID=
# 견적서 항목(라인 아이템) DB — Invoice와 Relation 연결
NOTION_ITEM_DB_ID=

# Auth.js (NextAuth v5)
# 생성: `openssl rand -base64 32` 또는 `npx auth secret`
AUTH_SECRET=

ADMIN_EMAIL=admin@example.com

ADMIN_PASSWORD_HASH=''

# 배포 URL (로컬 개발: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000